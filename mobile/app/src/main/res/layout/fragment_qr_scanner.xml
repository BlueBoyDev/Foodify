<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@color/surface_light"
    android:paddingBottom="32dp">

    <!-- Handle -->
    <View android:layout_width="40dp" android:layout_height="4dp"
        android:layout_gravity="center_horizontal" android:layout_marginTop="12dp"
        android:background="?android:attr/dividerVertical" />

    <TextView android:id="@+id/tv_scan_title"
        android:layout_width="match_parent" android:layout_height="wrap_content"
        android:text="Escanear QR de Orden"
        android:textSize="18sp" android:textStyle="bold"
        android:textColor="?attr/colorOnSurface"
        android:gravity="center" android:padding="16dp" />

    <!-- Vista de la cámara ZXing -->
    <com.journeyapps.barcodescanner.DecoratedBarcodeView
        android:id="@+id/barcode_view"
        android:layout_width="match_parent"
        android:layout_height="280dp" />

    <!-- Resultado del escaneo -->
    <TextView android:id="@+id/tv_scan_result"
        android:layout_width="match_parent" android:layout_height="wrap_content"
        android:text="Apunta la cámara al código QR del cliente"
        android:textSize="14sp"
        android:textColor="?android:attr/textColorSecondary"
        android:gravity="center"
        android:padding="16dp" />

    <!-- Botones -->
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="horizontal" android:paddingHorizontal="16dp">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_flashlight"
            style="@style/FoodifyButton.Outlined"
            android:layout_width="0dp" android:layout_height="48dp"
            android:layout_weight="1"
            android:text="Linterna"
            android:layout_marginEnd="8dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_cancel"
            style="@style/FoodifyButton"
            android:layout_width="0dp" android:layout_height="48dp"
            android:layout_weight="1"
            android:text="Cancelar"
            android:backgroundTint="?android:attr/textColorSecondary"
            app:backgroundTint="?android:attr/textColorSecondary" />
    </LinearLayout>
</LinearLayout>