<?xml version="1.0" encoding="utf-8"?>
<!-- Panel inicio mesero — modo oscuro, 4 KPI cards + pedidos recientes — imagen 12 -->
<androidx.swiperefreshlayout.widget.SwipeRefreshLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/swipe_refresh"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <ScrollView android:layout_width="match_parent" android:layout_height="match_parent"
        android:background="?android:attr/colorBackground"
        android:fillViewport="true">

        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="vertical" android:padding="16dp">

            <!-- Header: Mesero + Logo + nombre mesero -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:gravity="center_vertical"
                android:layout_marginBottom="16dp">
                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:orientation="horizontal" android:gravity="center_vertical">
                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="32dp" android:layout_height="32dp"
                        app:cardCornerRadius="8dp"
                        app:cardBackgroundColor="@color/foodify_orange">
                        <ImageView android:layout_width="20dp" android:layout_height="20dp"
                            android:layout_gravity="center"
                            android:src="@drawable/ic_fork_spoon"
                            app:tint="@color/white" />
                    </com.google.android.material.card.MaterialCardView>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Mesero" android:textSize="18sp" android:textStyle="bold"
                        android:textColor="?attr/colorOnBackground" android:layout_marginStart="8dp" />
                </LinearLayout>
                <TextView android:id="@+id/tv_waiter_name"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Cargando..." android:textSize="14sp"
                    android:textColor="@color/foodify_orange" android:textStyle="bold" />
            </LinearLayout>

            <!-- KPI Grid 2x2 — modo oscuro -->
            <GridLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:columnCount="2" android:rowCount="2" android:useDefaultMargins="true">

                <!-- Pedidos Activos (azul) -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_columnWeight="1" android:layout_margin="6dp"
                    app:cardCornerRadius="20dp" app:cardBackgroundColor="@color/surface_light">
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:orientation="vertical" android:padding="16dp">
                        <View android:layout_width="40dp" android:layout_height="40dp"
                            android:background="@drawable/bg_kpi_icon"
                            android:backgroundTint="@color/icon_orders" />
                        <TextView android:id="@+id/tv_pending_count"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="0" android:textSize="28sp" android:textStyle="bold"
                            android:textColor="?attr/colorOnSurface" android:layout_marginTop="8dp" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Pedidos Activos" android:textSize="12sp"
                            android:textColor="?android:attr/textColorSecondary" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Completados Hoy (verde) -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_columnWeight="1" android:layout_margin="6dp"
                    app:cardCornerRadius="20dp" app:cardBackgroundColor="@color/surface_light">
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:orientation="vertical" android:padding="16dp">
                        <View android:layout_width="40dp" android:layout_height="40dp"
                            android:background="@drawable/bg_kpi_icon"
                            android:backgroundTint="@color/icon_sales" />
                        <TextView android:id="@+id/tv_completed_count"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="0" android:textSize="28sp" android:textStyle="bold"
                            android:textColor="?attr/colorOnSurface" android:layout_marginTop="8dp" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Completados Hoy" android:textSize="12sp"
                            android:textColor="?android:attr/textColorSecondary" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- En Cocina (naranja) -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_columnWeight="1" android:layout_margin="6dp"
                    app:cardCornerRadius="20dp" app:cardBackgroundColor="@color/surface_light">
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:orientation="vertical" android:padding="16dp">
                        <View android:layout_width="40dp" android:layout_height="40dp"
                            android:background="@drawable/bg_kpi_icon"
                            android:backgroundTint="@color/foodify_orange" />
                        <TextView android:id="@+id/tv_in_kitchen_count"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="0" android:textSize="28sp" android:textStyle="bold"
                            android:textColor="?attr/colorOnSurface" android:layout_marginTop="8dp" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="En Cocina" android:textSize="12sp"
                            android:textColor="?android:attr/textColorSecondary" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Ventas del Día (tendencia) -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_columnWeight="1" android:layout_margin="6dp"
                    app:cardCornerRadius="20dp" app:cardBackgroundColor="@color/surface_light">
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:orientation="vertical" android:padding="16dp">
                        <View android:layout_width="40dp" android:layout_height="40dp"
                            android:background="@drawable/bg_kpi_icon"
                            android:backgroundTint="@color/accent_green" />
                        <TextView android:id="@+id/tv_sales_today"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="$0" android:textSize="20sp" android:textStyle="bold"
                            android:textColor="?attr/colorOnSurface" android:layout_marginTop="8dp" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Ventas del Día" android:textSize="12sp"
                            android:textColor="?android:attr/textColorSecondary" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

            </GridLayout>

            <!-- Pedidos Recientes -->
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Pedidos Recientes" android:textSize="18sp" android:textStyle="bold"
                android:textColor="?attr/colorOnBackground" android:layout_marginTop="16dp"
                android:layout_marginBottom="8dp" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rv_recent_orders"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:nestedScrollingEnabled="false" />

            <!-- Botones Nueva Orden / Ver Menú -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:layout_marginTop="20dp">
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_new_order"
                    style="@style/FoodifyButton"
                    android:layout_width="0dp" android:layout_height="52dp"
                    android:layout_weight="1"
                    android:text="Nueva Orden"
                    android:layout_marginEnd="8dp" />
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_view_menu"
                    style="@style/FoodifyButton.Outlined"
                    android:layout_width="0dp" android:layout_height="52dp"
                    android:layout_weight="1"
                    android:text="Ver Menú" />
            </LinearLayout>

        </LinearLayout>
    </ScrollView>
</androidx.swiperefreshlayout.widget.SwipeRefreshLayout>