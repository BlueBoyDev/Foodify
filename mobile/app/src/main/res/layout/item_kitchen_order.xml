<?xml version="1.0" encoding="utf-8"?>
<!-- Card de comanda — borde de urgencia + ítems + botón contextual -->
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/card_order"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="16dp"
    android:layout_marginVertical="8dp"
    app:cardCornerRadius="20dp"
    app:cardElevation="4dp"
    app:cardBackgroundColor="?attr/colorSurface"
    app:strokeWidth="1dp"
    app:strokeColor="?attr/colorSurface">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Header: número, mesa, tiempo, badge estado -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:gravity="center_vertical">

            <TextView android:id="@+id/tv_order_number" android:layout_width="wrap_content"
                android:layout_height="wrap_content" android:textSize="18sp"
                android:textStyle="bold" android:textColor="?attr/colorOnSurface"
                android:layout_marginEnd="8dp" />

            <TextView android:id="@+id/tv_table_label" android:layout_width="0dp"
                android:layout_height="wrap_content" android:layout_weight="1"
                android:textSize="14sp" android:textColor="?attr/colorOnSurface" />

            <!-- Agregado: tv_waiter_name para compatibilidad con KitchenAdapter -->
            <TextView android:id="@+id/tv_waiter_name"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:textSize="13sp" android:textColor="@color/text_low_dark"
                android:layout_marginEnd="12dp" />

            <!-- Badge estado cocina -->
            <TextView android:id="@+id/tv_kitchen_status"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:paddingHorizontal="10dp" android:paddingVertical="4dp"
                android:textSize="11sp" android:textColor="@color/surface_light"
                android:textStyle="bold" android:background="@drawable/bg_badge_round" />
        </LinearLayout>

        <!-- Tiempo transcurrido + conteo ítems -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:layout_marginTop="6dp">
            <ImageView android:layout_width="14dp" android:layout_height="14dp"
                android:src="@drawable/ic_time" android:tint="@color/text_low_dark" />
            <TextView android:id="@+id/tv_elapsed_time" android:layout_width="0dp"
                android:layout_height="wrap_content" android:layout_weight="1"
                android:textSize="12sp" android:textColor="@color/text_low_dark"
                android:layout_marginStart="4dp" />
            <TextView android:id="@+id/tv_item_count" android:layout_width="wrap_content"
                android:layout_height="wrap_content" android:textSize="12sp"
                android:textColor="?android:attr/textColorSecondary" />
        </LinearLayout>

        <!-- Divider -->
        <View android:layout_width="match_parent" android:layout_height="1dp"
            android:background="?android:attr/listDivider" android:layout_marginVertical="10dp" />

        <!-- Lista de ítems de la comanda -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rv_order_items"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:nestedScrollingEnabled="false" />

        <!-- Notas especiales del mesero al chef -->
        <TextView android:id="@+id/tv_special_notes"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:padding="8dp"
            android:background="@drawable/bg_notes"
            android:textSize="12sp" android:textColor="@color/foodify_orange"
            android:visibility="gone" />

        <!-- Botones de acción -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:layout_marginTop="12dp">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_edit"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="0dp" android:layout_height="48dp"
                android:layout_weight="1" android:text="✎ Editar"
                android:layout_marginEnd="8dp"
                app:strokeColor="@color/foodify_orange"
                android:textColor="@color/foodify_orange"
                app:cornerRadius="12dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_action"
                style="@style/FoodifyButton"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:text="Iniciar Preparación"
                android:visibility="gone" />
        </LinearLayout>

    </LinearLayout>
</com.google.android.material.card.MaterialCardView>