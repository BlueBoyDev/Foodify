<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:paddingVertical="4dp"
    android:gravity="center_vertical">

    <View
        android:id="@+id/view_status_indicator"
        android:layout_width="8dp"
        android:layout_height="8dp"
        android:layout_marginEnd="8dp"
        android:background="@drawable/bg_circle"
        android:backgroundTint="@color/status_available" />

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical">
        
        <TextView
            android:id="@+id/tv_lot_number"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="12sp"
            android:textColor="@color/text_high_light"
            android:text="Lote #123" />
            
        <TextView
            android:id="@+id/tv_expiry_date"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="11sp"
            android:textColor="@color/text_low_light"
            android:text="Caduca: 10/10/2026" />
    </LinearLayout>

    <TextView
        android:id="@+id/tv_lot_quantity"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textSize="14sp"
        android:textStyle="bold"
        android:textColor="@color/foodify_orange"
        android:text="5.0 kg" />

    <ImageButton
        android:id="@+id/btn_edit_lot"
        android:layout_width="32dp"
        android:layout_height="32dp"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:src="@drawable/ic_edit"
        android:contentDescription="Editar lote"
        android:layout_marginStart="8dp"
        app:tint="@color/text_low_light"
        xmlns:app="http://schemas.android.com/apk/res-auto" />

    <ImageButton
        android:id="@+id/btn_delete_lot"
        android:layout_width="32dp"
        android:layout_height="32dp"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:src="@drawable/ic_delete"
        android:contentDescription="Eliminar lote"
        android:layout_marginStart="4dp"
        app:tint="@color/status_occupied"
        xmlns:app="http://schemas.android.com/apk/res-auto" />

</LinearLayout>
