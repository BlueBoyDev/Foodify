<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:paddingVertical="12dp"
    android:gravity="center_vertical">

    <View
        android:layout_width="4dp"
        android:layout_height="24dp"
        android:background="@color/foodify_orange"
        android:layout_marginEnd="12dp"/>

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/tv_staff_name"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Nombre del Mesero"
            android:textStyle="bold"
            android:textSize="14sp"
            android:textColor="?attr/colorOnSurface"/>

        <TextView
            android:id="@+id/tv_staff_orders"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="15 pedidos"
            android:textSize="12sp"
            android:textColor="?android:attr/textColorSecondary"/>
    </LinearLayout>

    <TextView
        android:id="@+id/tv_staff_revenue"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="$1,250.00"
        android:textStyle="bold"
        android:textSize="16sp"
        android:textColor="@color/foodify_orange"/>

</LinearLayout>
